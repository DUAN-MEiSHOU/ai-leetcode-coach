{
  "manifest_version": 3,
  "name": "AI LeetCode Coach",
  "description": "A Side Panel learning coach shell for user-selected LeetCode context.",
  "version": "0.2.0",
  "minimum_chrome_version": "114",
  "permissions": ["sidePanel", "contextMenus", "storage", "activeTab"],
  "action": {
    "default_title": "Open AI LeetCode Coach"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  }
}
