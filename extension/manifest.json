{
  "manifest_version": 3,
  "name": "AI LeetCode Coach",
  "description": "A Side Panel learning coach shell for user-selected LeetCode context.",
  "version": "0.4.0",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel", "contextMenus", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://leetcode.com/*",
    "https://leetcode.cn/*"
  ],
  "action": {
    "default_title": "Open AI LeetCode Coach"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*", "https://leetcode.cn/*"],
      "js": ["src/content/floating-entry.js"],
      "run_at": "document_idle"
    }
  ]
}
